# Copy to .env and fill in. Never commit .env.

# Gemini access for the offline pre-processing / benchmark pipeline, via Vertex AI
# (the "Agent Platform API", aiplatform.googleapis.com) on the Cloud project that
# holds the data-retention (prompt-logging) exception.
GOOGLE_GENAI_USE_VERTEXAI=true

# Pick ONE auth mode below — do NOT set both. If an API key AND project/location are
# both present, the SDK silently ignores the key and the call runs under the wrong
# identity.
#
# Mode 1 — API key (express mode): global endpoint, no region pinning. The key must
# belong to the project that carries the data-retention exception. Leave the two
# GOOGLE_CLOUD_* lines (Mode 2) blank/commented when using this.
GOOGLE_API_KEY=
#
# Mode 2 — Application Default Credentials: run `gcloud auth application-default login`
# once, then set the project (and a region to pin data residency). Leave GOOGLE_API_KEY
# blank when using this.
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=global

# Token gating the /admin endpoints.
ADMIN_TOKEN=

# Shared invite token gating the whole application (a distinct secret from
# ADMIN_TOKEN). Visitors reach the app via ?invite=<this value>; set once.
ACCESS_TOKEN=

# Optional. Set to false in local dev/test so cookies round-trip over plain HTTP.
# Defaults to true (production is HTTPS-only).
# COOKIE_SECURE=true

# Optional. Logging level: DEBUG / INFO / WARNING / ERROR. Defaults to INFO.
# LOG_LEVEL=INFO
